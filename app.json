{
  "expo": {
    "name": "Helprr",
    "slug": "helprr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "helprr",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.mohammadhelaly.helprr",
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Helprr to access your camera."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.mohammadhelaly.helprr",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.mohammadhelaly.helprr",
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Helprr to access your microphone.",
          "speechRecognitionPermission": "Allow Helprr to use speech recognition."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
